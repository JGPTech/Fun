def print_sweep(N_values: List[int], max_iter: int = 500):
    """
    Empirical sweep: T_3 vs sigma across N_values.
    Reports Cesaro compression, drift bounds, collapse times, conjugacy gap.
    """
    print(f"\n{'='*78}")
