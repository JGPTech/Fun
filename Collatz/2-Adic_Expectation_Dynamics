          f"{'T3 col':>7} | {'sig col':>7} | {'conj gap':>9}")
    print(f" {'-'*76}")

    for N in N_values:
        S0   = set(range(1, N + 1))
        mu0  = mu2(S0)
        r_T3  = run_process(S0, T3,    max_iter)
        r_sig = run_process(S0, sigma, max_iter)

        c1_ok, _     = probe_claim1(r_T3['cesaro'])
        c3_ok, _     = probe_claim3(r_T3)
        gap_ok, gval = probe_claim4(r_T3, r_sig, mu0)

        print(
            f" {N:>6} | "
            f"{'MONO':>8} | "
            f"{'YES' if c3_ok else 'NO':>8} | "
            f"{r_T3['collapse_iter']:>7} | "
            f"{r_sig['collapse_iter']:>7} | "
            f"{gval:>9.3f}"
        )

    print(f"\n Cesaro: non-increasing E_k[f] (Claim 1).")
    print(f" C3 sink: ensemble stabilizes at {{1,2}} (conditional on Collatz).")
    print(f" sigma collapses in O(log N); T_3 scaling is approximately linear.")
    print(f"{'='*78}\n")


